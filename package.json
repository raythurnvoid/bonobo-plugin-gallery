{
	"name": "@bonobo/plugin-gallery",
	"private": true,
	"version": "0.1.9",
	"type": "module",
	"scripts": {
		"build": "vite build && prettier --write dist/frontend/assets/index.js dist/frontend/assets/index.css && node scripts/build-manifest.mjs",
		"build:manifest": "node scripts/build-manifest.mjs",
		"dev": "vite",
		"test": "vitest",
		"test:once": "vitest run --testTimeout 30000 --hookTimeout 30000 --teardownTimeout 30000",
		"typecheck": "tsc --noEmit"
	},
	"packageManager": "pnpm@10.33.0",
	"dependencies": {
		"bonobo-plugin-sdk": "github:raythurnvoid/bonobo-plugin-sdk#4b30306029a903d37098743a475dd34acea298ee",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "16.3.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"happy-dom": "20.0.11",
		"prettier": "3.8.3",
		"typescript": "^7.0.2",
		"vite": "^8.1.4",
		"vitest": "^3.2.7"
	}
}
